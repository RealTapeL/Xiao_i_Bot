# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Model Provider (openai/zhipuai/dashscope/deepseek/minimax/moonshot)
MODEL_PROVIDER=deepseek

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.8

# ZhipuAI Settings
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=chatglm3-6b

# Dashscope Settings
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-turbo

# DeepSeek Settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# MiniMax Settings
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_MODEL=abab5.5-chat

# Moonshot Settings
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_MODEL=moonshot-v1-8k

# Memory Settings
MAX_MEMORY_TOKENS=2000
MEMORY_SUMMARY_TOKENS=500

# Proactive Chat Settings
ENABLE_PROACTIVE_CHAT=true
PROACTIVE_CHAT_INTERVAL=3600
PROACTIVE_CHAT_START_HOUR=9
PROACTIVE_CHAT_END_HOUR=22

# Database
DATABASE_URL=sqlite:///./bot.db

# Proxy Settings (optional)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# System Monitor Settings
MONITOR_INTERVAL=5.0
TRIGGER_COOLDOWN=1800
CPU_THRESHOLD=80.0
IDLE_THRESHOLD=600
ACTIVITY_THRESHOLD=100
