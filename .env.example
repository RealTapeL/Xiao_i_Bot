# WeChat Bot Settings
WECHAT_AUTO_REPLY=true
WECHAT_AUTO_REPLY_KEYWORDS=           # 触发自动回复的关键词，逗号分隔，留空则回复所有消息
WECHAT_ADMIN_ID=                       # 管理员微信号（可选）

# Model Provider (openai/zhipuai/dashscope/deepseek/minimax/moonshot)
MODEL_PROVIDER=deepseek

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.8

# ZhipuAI Settings
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=chatglm3-6b

# Dashscope Settings
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-turbo

# DeepSeek Settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# MiniMax Settings
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_MODEL=abab5.5-chat

# Moonshot Settings
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_MODEL=moonshot-v1-8k

# Memory Settings
MAX_MEMORY_TOKENS=2000
MEMORY_SUMMARY_TOKENS=500

# Database
DATABASE_URL=sqlite:///./bot.db

# Proxy Settings (optional)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
